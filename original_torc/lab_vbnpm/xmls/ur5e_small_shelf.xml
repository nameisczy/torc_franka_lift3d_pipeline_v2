<mujoco model="World">
  <compiler angle="radian" />
  <option integrator="implicitfast" cone="elliptic" solver="CG" noslip_iterations="2">
    <flag warmstart="disable" multiccd="enable" />
  </option>
  <default>
    <geom density="10" />
  </default>
  <asset>
    <texture type="skybox" builtin="flat" rgb1="1 1 1" rgb2="0 0 0" width="512" height="3072" />
    <texture type="2d" name="grid" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" width="512" height="512" />
    <material name="grid" texture="grid" texuniform="true" texrepeat="0.5 0.5" emission="1" specular="0" shininess="0" />
  </asset>
  <worldbody>
    <geom name="floor" size="20 20 0.05" type="plane" material="grid" />
    <light pos="-0.5 0.5 5" dir="0 0 -1" castshadow="false" diffuse="1 1 1" />
    <body name="scene" />
    <body name="shelf" pos="0.7 0 0">
      <camera name="top_view" pos="0 0 0.9" quat="1 0 0 0" fovy="50"/>
      <!-- Shelf base (table) -->
      <geom name="shelf_base" pos="0 0 0.15" size="0.13 0.18 0.15" type="box" rgba="0.9 0.9 0.9 1" />
      <!-- Back wall (toward robot, -X side) -->
      <geom name="shelf_back_wall" pos="0.12 0 0.4" size="0.01 0.16 0.1" type="box" rgba="0.9 0.9 0.9 0.3" />
      <!-- Left wall (+Y side) -->
      <geom name="shelf_left_wall" pos="0 0.17 0.4" size="0.13 0.01 0.1" type="box" rgba="0.9 0.9 0.9 0.3" />
      <!-- Right wall (-Y side) -->
      <geom name="shelf_right_wall" pos="0 -0.17 0.4" size="0.13 0.01 0.1" type="box" rgba="0.9 0.9 0.9 0.3" />
      <!-- Ceiling/top -->
      <geom name="shelf_ceiling" pos="0 0 0.51" size="0.13 0.18 0.01" type="box" rgba="0.9 0.9 0.9 0.3" />
    </body>
  </worldbody>
</mujoco>
