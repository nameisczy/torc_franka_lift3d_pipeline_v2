      <geom name="shelf_padding_back" size="0.05 0.63 0.3" pos="0.35 0 1.25" type="box" material="table_ceramic"/>
    </body>
    <include file="robot_body.xml"/>
    <body name="003_cracker_box" pos="1.01 -0.13 1.05" quat="-0.0047043 0.978247 -0.206916 -0.0140083">
      <joint type="free"/>
      <geom type="mesh" contype="3" conaffinity="3" group="1" material="003_cracker_box" mesh="003_cracker_box_vis"/>
