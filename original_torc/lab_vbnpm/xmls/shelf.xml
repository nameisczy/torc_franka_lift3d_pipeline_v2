    <body name="workspace" pos="1.15 0 0">
      <geom name="shelf_bottom" size="0.4 0.68 0.475" pos="0 0 0.475" type="box" material="table_ceramic"/>
      <geom name="shelf_top" size="0.4 0.68 0.025" pos="0 0 1.525" type="box" material="table_ceramic"/>
      <geom name="shelf_padding_left" size="0.4 0.025 0.3" pos="0 -0.655 1.25" type="box" material="table_ceramic"/>
