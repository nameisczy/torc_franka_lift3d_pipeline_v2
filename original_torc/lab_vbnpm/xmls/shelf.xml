    <body name="008_pudding_box" pos="0.96 0.13 1.00" quat="-0.223084 -0.244111 0.698893 0.634186">
      <joint type="free"/>
      <geom type="mesh" contype="3" conaffinity="3" group="1" material="008_pudding_box" mesh="008_pudding_box_vis" euler="-.04 0 1.09"/>
      <!-- <geom type="box" contype="3" conaffinity="3" group="3" size=".045 .055 .018" mass="0.000187"/> -->
    </body>
    <body name="009_gelatin_box" pos="0.92 -0.22 0.96" quat="-0.0711878 -0.705203 -0.0978693 -0.698601">
      <joint type="free"/>
      <geom type="mesh" contype="3" conaffinity="3" group="1" material="009_gelatin_box" mesh="009_gelatin_box_vis" euler="0 0 -.25"/>
      <!-- <geom type="box" contype="3" conaffinity="3" group="3" size=".036 .044 .014" mass="0.000097"/> -->
    </body>
    <body name="010_potted_meat_can" pos="0.92 0.2 0.99" quat="-0.240264 -0.000278726 0.00211749 -0.970705">
      <joint type="free"/>
      <geom type="mesh" contype="3" conaffinity="3" group="1" material="010_potted_meat_can" mesh="010_potted_meat_can_vis" euler="0 0 -.05"/>
      <!-- <geom type="box" contype="3" conaffinity="3" group="3" size=".048 .026 .041" mass="0.000370"/> -->
