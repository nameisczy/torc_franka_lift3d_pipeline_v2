    <mesh name="017_orange_vis" file="models/objects/ycb_se3tn/017_orange/textured_simple.obj"/>

  </asset>
  <worldbody>
    <geom name="floor" size="2 2 0.05" type="plane" material="grid" condim="3"/>
    <light directional="true" pos="-0.5 0.5 3" dir="0 0 -1" castshadow="false" diffuse="1 1 1"/>
    <body name="workspace" pos="1.1 0 0" quat="1 0 0 0">
      <geom name="shelf_bottom" pos="0 0 0.475" material="table_ceramic" size="0.25 0.68 0.475" type="box" quat="1 0 0 0"/>
      <geom name="shelf_top" pos="0 0 1.49" material="table_ceramic" size="0.25 0.68 0.04" type="box" quat="1 0 0 0"/>
      <geom name="shelf_padding_left" pos="0 -0.655 1.2" material="table_ceramic" size="0.25 0.025 0.25" type="box" quat="1 0 0 0"/>
      <geom name="shelf_padding_right" pos="0 0.655 1.2" material="table_ceramic" size="0.25 0.025 0.25" type="box" quat="1 0 0 0"/>
      <geom name="shelf_padding_back" pos="0.225 0 1.2" material="table_ceramic" size="0.025 0.63 0.25" type="box" quat="1 0 0 0"/>
      <!-- blocks to avoid objects to fall -->
        <geom name="block_xmin" pos="-0.13 0 1.0" size="0.01 0.4 0.05" type="box" material="table_ceramic"/>      
        <geom name="block_xmax" pos="0.13 0 1.0" size="0.01 0.4 0.05" type="box" material="table_ceramic"/>      
        <geom name="block_ymin" pos="0 -0.23 1.0" size="0.2 0.01 0.05" type="box" material="table_ceramic"/>      
        <geom name="block_ymax" pos="0 0.23 1.0" size="0.2 0.01 0.05" type="box" material="table_ceramic"/>      
        <!-- <geom name="block_xmin" pos="-0.1 0 1.05" size="0.01 0.4 0.1" type="box" material="table_ceramic"/>      
        <geom name="block_xmax" pos="0.1 0 1.05" size="0.01 0.4 0.1" type="box" material="table_ceramic"/>      
        <geom name="block_ymin" pos="0 -0.2 1.05" size="0.2 0.01 0.1" type="box" material="table_ceramic"/>      
        <geom name="block_ymax" pos="0 0.2 1.05" size="0.2 0.01 0.1" type="box" material="table_ceramic"/>       -->

    </body>
    <body name="001_chips_can" pos="10 -0.09 1.05" quat="1 0 0 0">
      <joint type="free"/>
      <geom type="mesh" contype="0" conaffinity="0" group="1" material="001_chips_can" mesh="001_chips_can_vis" euler="0 0 1.9"/>
      <geom type="cylinder" contype="3" conaffinity="3" group="3" pos="0 0 0.014" size=".038 .12"/>
    </body>
    <body name="003_cracker_box" pos="10 -0.13 1.05" quat="1 0 0 0">
      <joint type="free"/>
      <geom name="003_cracker_box" type="mesh" contype="3" conaffinity="3" group="1" material="003_cracker_box" mesh="003_cracker_box_vis"/>
    </body>
    <body name="004_sugar_box" pos="10 0.25 1.05" quat="1 0 0 0">
      <joint type="free"/>
      <geom name="004_sugar_box" type="mesh" contype="3" conaffinity="3" group="1" material="004_sugar_box" mesh="004_sugar_box_vis" euler="0.01 .02 0"/>
    </body>
    <body name="005_tomato_soup_can" pos="10 0.26 1.05" quat="0.5 0 0 0.5">
      <joint type="free"/>
      <geom type="mesh" contype="3" conaffinity="3" group="1" material="005_tomato_soup_can" mesh="005_tomato_soup_can_vis"/>
    </body>
    <body name="006_mustard_bottle" pos="10 0.12 1.1" quat="1 0 0 0">
      <joint type="free"/>
      <geom name="006_mustard_bottle" type="mesh" contype="3" conaffinity="3" group="1" material="006_mustard_bottle" mesh="006_mustard_bottle_vis" pos="0.002 0 0" euler="0 0 -1.19"/>
    </body>
    <body name="008_pudding_box" pos="10 0.18 1.00" quat="1 0 0 0">
      <joint type="free"/>
      <geom name="008_pudding_box" type="mesh" contype="3" conaffinity="3" group="1" material="008_pudding_box" mesh="008_pudding_box_vis" euler="-.04 0 1.09"/>
    </body>
    <body name="010_potted_meat_can" pos="10 0.1 1.0" quat="1 0 0 0">
      <joint type="free"/>
      <geom name="010_potted_meat_can" type="mesh" contype="3" conaffinity="3" group="1" material="010_potted_meat_can" mesh="010_potted_meat_can_vis" euler="0 0 -.05"/>
    </body>
