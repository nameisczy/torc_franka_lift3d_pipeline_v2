      <geom type="mesh" contype="0" conaffinity="0" group="1" material="011_banana" mesh="011_banana_vis"/>
      <geom type="cylinder" contype="3" conaffinity="3" group="3" pos="-0.015 -0.045 0.001" euler="1.6 0 0" size=".016 .05"/>
      <geom type="sphere" contype="3" conaffinity="3" group="3" pos="-0.013 0.011 0.002" size=".018"/>
      <geom type="cylinder" contype="3" conaffinity="3" group="3" pos="0.009 0.038 0.002" euler="1.57 -0.7 0" size=".017 .03"/>
      <geom type="sphere" contype="3" conaffinity="3" group="3" pos="0.035 0.065 -0.002" size=".014"/>
      <geom type="cylinder" contype="3" conaffinity="3" group="3" pos="0.06 0.07 -0.01" zaxis="0.8 0.1 -0.1" size=".0055 .013"/>
    </body>
    <body name="013_apple" pos="10 -0.42 1.0" quat="1 0 0 0">
