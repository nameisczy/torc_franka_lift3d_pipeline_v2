<launch>
  <arg name="camera1" default="d455"/>
  <arg name="camera2" default="d435"/>
  <arg name="client_only" default="False" />
  <arg name="robot_config" default="$(find lab_vbnpm)/robots/motoman/motoman_filter.yaml" />

  <!-- Prerequisite: sensor_filters -->
  <!-- http://wiki.ros.org/sensor_filters -->
  <!-- <node name="pcd_filter" pkg="sensor_filters" type="pointcloud2_filter_chain" output="screen"> -->
  <!--     <rosparam command="load" file="$(arg robot_config)" /> -->
  <!--     <remap from="~input" to="velodyne_points" /> -->
  <!--     <remap from="~output" to="velodyne_points_filtered" /> -->
  <!-- </node> -->

  <node name="$(arg camera1)_set_dyn_config_preset" pkg="dynamic_reconfigure" type="dynparam"
    args="set_from_parameters $(arg camera1)/stereo_module">
    <param name="visual_preset" value="3" />
    <!-- <param name="inter_cam_sync_mode" value="1" /> -->
    <param name='enable_auto_exposure' value='False' />
    <param name='exposure' value='25000' />
    <param name='emitter_enabled' value='0' />
    <param name='laser_power' value='0.0' />
  </node>
  <node name="$(arg camera2)_set_dyn_config_preset" pkg="dynamic_reconfigure" type="dynparam"
    args="set_from_parameters $(arg camera2)/stereo_module">
    <param name="visual_preset" value="3" />
    <!-- <param name="inter_cam_sync_mode" value="2" /> -->
    <param name='enable_auto_exposure' value='False' />
    <param name='exposure' value='7000' />
    <param name='emitter_enabled' value='0' />
    <param name='laser_power' value='0.0' />
  </node>

  <include file="$(find segment3d)/launch/container_gsam.launch" unless="$(arg client_only)"/>
  <node name="segment3d_gsam_client" pkg="segment3d" type="gsam_service.py" output="screen" if="$(arg client_only)"/>

</launch>
