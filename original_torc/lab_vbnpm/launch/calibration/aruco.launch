<launch>

  <arg name="marker1Id"         default="439"/> <!-- bottom left -->
  <arg name="marker2Id"         default="218"/> <!-- top right -->
  <arg name="markerSize"        default="0.04"/>    <!-- in m -->
  <arg name="camera"            default="d435" />
  <arg name="marker1_frame"     default="bottom_left" />
  <arg name="marker2_frame"     default="top_right" />
  <arg name="ref_frame"       default=""/>  <!-- leave empty and the pose will be published wrt param parent_name -->

  <node pkg="aruco_ros" type="single" name="aruco_single_1">
    <remap from="/camera_info" to="/$(arg camera)/color/camera_info" />
    <remap from="/image" to="/$(arg camera)/color/image_raw" />
    <param name="image_is_rectified" value="True"/>
    <param name="marker_size"        value="$(arg markerSize)"/>
    <param name="marker_id"          value="$(arg marker1Id)"/>
    <param name="reference_frame"    value="$(arg ref_frame)"/>   <!-- frame in which the marker pose will be refered -->
    <!-- <param name="camera_frame"       value="camera_color_optical_frame"/>  -->
    <!-- reserved: camera_link, camera_color_optical_frame -->
    <param name="camera_frame"       value="$(arg camera)_color_optical_frame"/> <!-- reserved: camera_link, camera_color_optical_frame -->
    <param name="marker_frame"       value="$(arg marker1_frame)" />
  </node>

  <node pkg="aruco_ros" type="single" name="aruco_single_2">
    <remap from="/camera_info" to="/$(arg camera)/color/camera_info" />
    <remap from="/image" to="/$(arg camera)/color/image_raw" />
    <param name="image_is_rectified" value="True"/>
    <param name="marker_size"        value="$(arg markerSize)"/>
    <param name="marker_id"          value="$(arg marker2Id)"/>
    <param name="reference_frame"    value="$(arg ref_frame)"/>   <!-- frame in which the marker pose will be refered -->
    <!-- <param name="camera_frame"       value="camera_color_optical_frame"/>  -->
    <!-- reserved: camera_link, camera_color_optical_frame -->
    <param name="camera_frame"       value="$(arg camera)_color_optical_frame"/> <!-- reserved: camera_link, camera_color_optical_frame -->
    <param name="marker_frame"       value="$(arg marker2_frame)" />
  </node>

</launch>

