    help="Collects rosbag data (takes around 60 GB of space per bag).",
)
experiment_parser.add_argument(
    "--headless",
    action="store_true",
    help="Disables graphics like MuJoCo viewer and RViz while running.",
)
experiment_parser.add_argument(
    "--dry",
    action="store_true",
    help="Performs a dry run, outputing what experiements it would run without actually running them.",
)
experiment_parser.add_argument(
    "--pick-limit",
    type=int,
    default=15,
    help="Maximum number of picks before the process ends. Default is 15. Use -1 for unlimited picks. Use 0 to collect images only.",
)
experiment_parser.add_argument(
    "--server",
    action="store_true",
    help="Spins up a server to run headless experiments. Faster if you're running multiple experiments.",
)
experiment_parser.add_argument(
    "--base-dir",
    type=str,
    help="Base directory to store runs in. Will be created if it does not exist. Relative to runs dir, or an absolute path.",
)
experiment_parser.add_argument(
    "--real",
    action="store_true",
    help="Performs a real run not in simulation.",
)
experiment_parser.add_argument(
    "--docker",
    action="store_true",
    help="Runs the docker ros_config, which is headless and excludes the grasp planner. The grasp planner is assumed to run in its own docker container.",
)
experiment_parser.add_argument(
    "--profile-grasping",
    action="store_true",
    help="Profiles the time taken for each step of the grasping process and saves it to profile_grasping.json in the experiment directory.",
)
experiment_parser.add_argument(
    "--profiler",
    type=str,
    default=Profiler.LINE_PROFILER.value,
    choices=Profiler.values(),
    help="Profiler to use for grasping choice function.",
)
experiment_parser.add_argument(
    "--mj-pickle",
    action="store_true",
    help="Tells motoman_node to record mj_pickles during the experiment.",
)


args = parser.parse_args()
if args.mode == "trial":
    args = TrialArgs(**vars(args))
elif args.mode == "resume_trial":
    args = ResumeTrialArgs(**vars(args))
elif args.mode == "experiment":
    args = ExperimentArgs(**vars(args))
else:
    printerr("Unknown mode: ", args.mode)
    exit(1)

print("🧪 run_experiment:")
max_arg_len = max(len(arg) for arg in args.__dict__)
for arg, value in args.__dict__.items():
    print(f"  {arg.ljust(max_arg_len)} {value}")
print()

exit_code = 0
try:
    if args.base_dir:
        if os.path.isabs(args.base_dir):
            RUN_BASE_DIR = args.base_dir
        else:
            RUN_BASE_DIR = os.path.abspath(os.path.join(RUNS_DIR, args.base_dir))
        os.makedirs(RUN_BASE_DIR, exist_ok=True)
    if args.server:
        init_sockets(args.real, args.docker)
    if args.mode == "resume_trial":
        resume_trial(
            trial_dir=args.trial_dir,
            dry=args.dry,
            server=args.server,
            rerun_error=args.rerun_error,
        )
    elif args.mode in ["trial", "experiment"]:
        for method in args.method:
            if args.mode == "trial":
                success = True
                for file in args.files:
                    success = success and run_trial(
                        config_yaml=file,
                        method=method,
                        rosbag=args.rosbag,
                        headless=args.headless,
                        dry=args.dry,
                        pick_limit=args.pick_limit,
                        server=args.server,
                        real=args.real,
                        rerun_error=args.rerun_error,
                        profile_grasping=args.profile_grasping,
                        profiler=args.profiler,
                        mj_pickle=args.mj_pickle,
                    )
                if success:
                    print(
                        "\n",
                        Fore.GREEN,
                        f"✅ Stopping with all trials successful.",
                        Style.RESET_ALL,
                    )
                    exit_code = 0
                else:
                    print(
                        "\n",
                        Fore.RED,
                        f"❌ Stopping with some errors in trial runs.",
                        Style.RESET_ALL,
                    )
                    exit_code = 1
            elif args.mode == "experiment":
                run_experiment(
                    scene=args.scene,
                    target_object=args.target_object,
                    rosbag=args.rosbag,
                    method=method,
                    headless=args.headless,
                    dry=args.dry,
                    pick_limit=args.pick_limit,
                    server=args.server,
                    real=args.real,
                    profile_grasping=args.profile_grasping,
                    profiler=args.profiler,
                    mj_pickle=args.mj_pickle,
                )
    else:
        exiterr(f"Unknown mode: {args.mode}")
except KeyboardInterrupt:
    pass
finally:
    if args.server:
        stop_sockets()
exit(exit_code)
