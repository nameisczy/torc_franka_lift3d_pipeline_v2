class Method(str, Enum):
    ALL_AUTO = "all_auto"
    HUMAN = "human"
    VLM_ONLY = "vlm_only"
    DG_ONLY = "dg_only"
    DG_INTO_VLM = "dg_into_vlm"
    VLM_DG = "vlm_dg"
    RANDOM = "random"

    @staticmethod
    def values():
        return [method.value for method in Method]

    @staticmethod
    def values_all_auto():
        return [
            method.value
            for method in Method
            if method not in [Method.ALL_AUTO, Method.HUMAN]
        ]


class Profiler(str, Enum):
    CPROFILE = "c_profile"
    LINE_PROFILER = "line_profiler"

    @staticmethod
    def values():
        return [profiler.value for profiler in Profiler]


