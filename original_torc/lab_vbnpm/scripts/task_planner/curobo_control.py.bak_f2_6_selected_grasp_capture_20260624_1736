    def _logged_wait_for_message(topic, topic_type, *wait_args, **wait_kwargs):
        timeout = wait_kwargs.get("timeout", None)
        if timeout is None and wait_args:
            timeout = wait_args[0]
        type_name = getattr(topic_type, "__name__", str(topic_type))
        stage_log(
            "WAIT ROS topic begin",
            f"topic={topic} type={type_name} timeout={timeout}",
        )
        wait_t0 = time.time()
        try:
            msg = _orig_wait_for_message(
                topic, topic_type, *wait_args, **wait_kwargs
            )
            stage_log(
                "WAIT ROS topic done",
                f"topic={topic} elapsed={time.time() - wait_t0:.3f}s",
            )
            return msg
        except Exception as exc:
            stage_log(
                "WAIT ROS topic error",
                f"topic={topic} elapsed={time.time() - wait_t0:.3f}s "
                f"error={type(exc).__name__}: {exc}",
            )
            raise

    def _logged_wait_for_service(service, *wait_args, **wait_kwargs):
        timeout = wait_kwargs.get("timeout", None)
        if timeout is None and wait_args:
            timeout = wait_args[0]
        stage_log(
            "WAIT ROS service begin",
            f"service={service} timeout={timeout}",
        )
        wait_t0 = time.time()
        try:
