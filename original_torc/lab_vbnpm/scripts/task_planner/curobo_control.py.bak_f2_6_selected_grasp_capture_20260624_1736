        message = f"[CUROBO_STAGE {timestamp} +{elapsed:9.3f}s] {stage}"
        if detail:
            message += f" | {detail}"
        print(message, flush=True)
        if STAGE_LOG_FILE:
            try:
                os.makedirs(os.path.dirname(STAGE_LOG_FILE), exist_ok=True)
                with open(STAGE_LOG_FILE, "a") as stage_file:
                    print(message, file=stage_file, flush=True)
