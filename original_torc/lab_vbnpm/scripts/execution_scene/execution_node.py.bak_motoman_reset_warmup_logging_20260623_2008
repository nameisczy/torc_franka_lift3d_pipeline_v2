        msg.header.frame_id = f"camera{camera_id}_color_optical_frame"
        msg.header.stamp = now
        self.depth_cam_pub[camera_id].publish(msg)

        msg = self.bridge.cv2_to_imgmsg(seg_img, "rgb8")
        msg.header.frame_id = f"camera{camera_id}_color_optical_frame"
        msg.header.stamp = now
        self.seg_cam_pub[camera_id].publish(msg)

    def publish_joint_state(self, now):
        pass

    def publish_ground_truth_state(self, now):
        names = []
        poses = []
        ids = []
        markerArray = MarkerArray()
        for i in range(self.model.nbody):
            body = self.model.body(i)
            dbody = self.data.body(i)
            name = body.name
            if name[:7] == "object_" or name[0] == "0" or name[:4] == "obj_":
                # get qpos indices for joint
                # iqpos = self.get_objq_indices(name)
                # pos_quat = self.data.qpos[iqpos]
                mat1 = np.eye(4)
                mat1[:3, :3] = dbody.xmat.reshape(3, 3)
                mat1[:3, 3] = dbody.xpos
                mat2 = self.geom2body[name + "_vis"]
                mat = mat1 @ mat2
                quat = tf.quaternion_from_matrix(mat)
                pos = mat[:3, 3]
                pose = Pose()
                pose.position.x = pos[0]
                pose.position.y = pos[1]
                pose.position.z = pos[2]
                pose.orientation.w = quat[0]
                pose.orientation.x = quat[1]
                pose.orientation.y = quat[2]
                pose.orientation.z = quat[3]
                names.append(name)
                poses.append(pose)
                ids.append(i)
                # make marker
                marker = Marker()
                marker.text = name
                marker.id = i
                marker.header.frame_id = "world"
                marker.pose = pose
                # print("assets: ")
                # pprint.pp(self.assets)
                if self.geom_type[name + "_vis"] == "mesh":
                    rel_path = self.assets[name + "_vis"].replace(self.pkg_path, "")
                    marker.mesh_resource = "package://lab_vbnpm" + rel_path
                    # marker.mesh_resource = 'file://' + self.assets[name + '_vis']
                    marker.mesh_use_embedded_materials = True
                    marker.type = marker.MESH_RESOURCE
                    marker.scale.x = 1.0
                    marker.scale.y = 1.0
                    marker.scale.z = 1.0
                elif self.geom_type[name + "_vis"] == "box":
                    marker.type = marker.CUBE
                    sx = self.model.geom(self.model.body(i).geomadr[0]).size[0] * 2
                    sy = self.model.geom(self.model.body(i).geomadr[0]).size[1] * 2
                    sz = self.model.geom(self.model.body(i).geomadr[0]).size[2] * 2
                    marker.scale.x = sx
                    marker.scale.y = sy
                    marker.scale.z = sz
                    marker.color.r = self.model.geom(
                        self.model.body(i).geomadr[0]
                    ).rgba[0]
                    marker.color.g = self.model.geom(
                        self.model.body(i).geomadr[0]
                    ).rgba[1]
                    marker.color.b = self.model.geom(
                        self.model.body(i).geomadr[0]
                    ).rgba[2]
                    marker.color.a = self.model.geom(
                        self.model.body(i).geomadr[0]
                    ).rgba[3]
                markerArray.markers.append(marker)

        # pub poses
        msg = ObjectPoses()
        msg.header.stamp = now
        msg.name = names
        msg.pose = poses
        msg.id = ids
        self.gt_obj_pub.publish(msg)
        # visualize markers
        self.rviz_pub.publish(markerArray)
        # publish selected object id
        if self.gui and self.viewer is not None:
            perturb_obj_id = -1
            if USE_MUJOCO_PY_VIEWER:
                if self.viewer.is_alive:
                    perturb_obj_id = self.viewer.pert.select
            else:
                if self.viewer.is_running():
                    perturb_obj_id = self.viewer.perturb.select

            if perturb_obj_id > -1:
                self.gt_pub_selected.publish(Int32(data=perturb_obj_id))
                name = self.model.body(perturb_obj_id).name
                self.gt_pub_selected_name.publish(String(data=name))
        # publish id to name mapping
        msg = ObjectIdsToNames()
        obj_ids = list(range(self.model.nbody))
        obj_names = [self.model.body(i).name for i in obj_ids]
        msg.obj_ids = obj_ids
        msg.names = obj_names
        self.obj_ids_to_names_pub.publish(msg)

    def fake_obj_control(self, req):
        """
        *fake perception for unit testing*
        directly apply force:torque to the object through data.xfrc_applied
        for a set time
        """
        obj_id = req.obj_id
        duration = req.duration
        force = [req.wrench.force.x, req.wrench.force.y, req.wrench.force.z]
        torque = [req.wrench.torque.x, req.wrench.torque.y, req.wrench.torque.z]
        applied_wrench = force + torque
        applied_wrench = np.array(applied_wrench)
        start_time = time.time()
        while time.time() - start_time < duration:
            self.data.xfrc_applied[obj_id, :] = applied_wrench
        return FakeObjectControlResponse()

    def publish_slow(self, clock_param):
        if not self.model_ready:
            return

        if self.renderer is None:
            self.renderer = mujoco.Renderer(self.model, 1080, 1920)

        now = rospy.Time.now()
        for i in range(self.model.ncam):
            self.publish_camera_info(i, now)
            self.publish_image(i, now)

    def publish_fast(self, clock_param):
        if not self.model_ready:
            return

        now = rospy.Time.now()
        self.publish_ground_truth_state(now)
        self.publish_joint_state(now)

    def step(self, sync_viewer: bool = True):
        self.do_traj()
        with self.mj_lock:
            mujoco.mj_step(self.model, self.data)
        if sync_viewer and self.viewer is not None:
            if USE_MUJOCO_PY_VIEWER:
                if self.viewer.is_alive:
                    # glfw.make_context_current(self.viewer.window)
                    self.viewer.render()
            else:
                if self.viewer.is_running():
                    self.viewer.sync()
        self.step_clock()

    def step_clock(self, use_model_time: bool = True):
        if use_model_time:
            timestep = self.model.opt.timestep
        else:
            # We must keep the clock stepping even if the model is not ready
            # in order of rospy timers to keep running
            timestep = 0.1
        self.sim_clock.clock += float_to_ros_duration(timestep)
        self.clock_pub.publish(self.sim_clock)

    def do_traj(self):
        """
        track the trajectory if there are ones inside the saved list
        """
        # * controlling arm
        if self.arm_trajectory:
            joint_names, position, velocity, _time = self.arm_trajectory.pop(0)
            iqpos = self.get_qpos_indices(joint_names)
            pctrl = self.get_ctrl_indices(joint_names)
            # vctrl = self.get_ctrl_indices(joint_names, replace='_v')
            intact = self.get_act_indices(joint_names, replace="_intv")
            intvctrl = self.get_ctrl_indices(joint_names, replace="_intv")
            self.data.ctrl[pctrl] = position
            # self.data.ctrl[vctrl] = velocity
            self.data.act[intact] = position
            self.data.ctrl[intvctrl] = velocity
        else:
            iqpos = self.get_qpos_indices(self.joint_names)
            # pctrl = self.get_ctrl_indices(self.joint_names)
            # vctrl = self.get_ctrl_indices(self.joint_names, replace='_v')
            intact = self.get_act_indices(self.joint_names, replace="_intv")
            intvctrl = self.get_ctrl_indices(self.joint_names, replace="_intv")
            # self.data.ctrl[pctrl] = self.data.qpos[iqpos]
            # self.data.ctrl[vctrl] = 0
            self.data.ctrl[intvctrl] = 0

            is_active = self.arm_trajectory is not None
            is_active &= self.follow_trajectory_as.is_active()
            if is_active:
                rospy.loginfo("Trajectory is done!")
                result = FollowJointTrajectoryResult()
                result.error_code = 0
                self.follow_trajectory_as.set_succeeded(result)
                self.arm_trajectory = None

        # * controlling end effector
        if len(self.ee_trajectory) > 0:
            joint_names, position = self.ee_trajectory.pop(0)
            ctrl = self.get_ctrl_indices(joint_names)
            self.data.ctrl[ctrl] = position

    def socket_reply(self, _type: str, msg={}):
        self.socket.send_json({"type": _type, **msg})

    def socket_reply_error(self, msg):
        self.socket_reply("error", {"msg": str(msg)})

    def poll_socket(self):
        if not self.socket.poll(0):
            return

        req = self.socket.recv_json()
        cmd = req.get("cmd", "")
        print("Received req: ", req)
        if cmd == "reset":
            self.reset(**req["args"])
            for i in range(1000):
                self.step(False)
            self.socket_reply("success")
        else:
            self.socket_reply_error(f"Unknown cmd: {cmd}")

    def step_loop(self):
        if self.model_ready:
            # Step model if it's ready
            if self.tick_count <= 1000:
                # Skip the first 1000 ticks in the simulation
                self.step(False)
                self.tick_count += 1
            else:
                self.step()

    def backup_step_clock_loop(self):
        while not rospy.is_shutdown() and not self.kill_backup_clock_event.is_set():
            # Manually tick the clock if model is not ready to keep
            # ros timers and publishers going.
            if not self.model_ready:
                self.step_clock(use_model_time=False)
            else:
                # Sleep to stop the thread from taking up valuble execution time
                time.sleep(5)
        self.kill_backup_clock_event.clear()

    def run(self):
        """
        keep spinning and publishing to the ROS topics
        """

        context = zmq.Context()
        self.socket = context.socket(zmq.REP)
        self.socket.bind(self.address)

        # Must step mujoco in main thread b/c seg faults otherwise??
        while not rospy.is_shutdown():
            self.poll_socket()
            self.step_loop()


