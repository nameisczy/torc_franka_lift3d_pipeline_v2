    def __init__(self, address: str = "tcp://*:5858"):
        rp = rospkg.RosPack()

        # lock for thread-safe mujoco access to avoid race conditions
        self.mj_lock = threading.Lock()

        self.pkg_path = rp.get_path("lab_vbnpm")
        self.load_ros_param()
        self.model = None
        self.model_ready = False

        # * for tracking arm and control ee asynchronously
        self.arm_trajectory = None
        self.ee_trajectory = []

        self.publish_slow_timer = None
        self.publish_fast_timer = None

        self.kill_backup_clock_event = threading.Event()

        # * set up ROS interfaces
        # ** clock
        # * init clock pub
        self.clock_pub = rospy.Publisher("clock", Clock, queue_size=10)
        self.sim_clock = Clock()
        self.sim_clock.clock = rospy.Time(0)

        # ** services
        rospy.Service(
            "/ground_truth/fake_obj_control", FakeObjectControl, self.fake_obj_control
        )

        # ** messages
        self.bridge = CvBridge()
        self.obj_ids_to_names_pub = rospy.Publisher(
            f"/ground_truth/object_ids_to_names", ObjectIdsToNames, queue_size=5
        )
        self.gt_obj_pub = rospy.Publisher(
            "/ground_truth/object_poses", ObjectPoses, queue_size=5
        )
        self.rviz_pub = rospy.Publisher(
            "visualization_marker", MarkerArray, queue_size=1
        )

        # ** TF
        self.br = tf2_ros.TransformBroadcaster()

        # ** action servers
        # robot
        self.follow_trajectory_as = actionlib.SimpleActionServer(
            "/joint_trajectory_action",
            FollowJointTrajectoryAction,
            # self.follow_trajectory_cb,
            auto_start=False,
        )
        self.follow_trajectory_as.register_goal_callback(self.follow_trajectory_cb)
        self.follow_trajectory_as.register_preempt_callback(self.preempt_cb)
        self.follow_trajectory_as.start()

        self.address = address

        self.tick_count = 0

    def reset(
        self,
        xml_file: str,
        gui: bool = True,
        save_image_dir: Optional[str] = None,
        experiment_dir: Optional[str] = None,
        mj_pickle: bool = False,
    ):
        with self.mj_lock:
            print("RESETTING EXECUTION NODE -- MUJOCO_GL: ", os.environ["MUJOCO_GL"])

            self.model_ready = False
            self.mj_pickle = mj_pickle

            self.backup_step_clock_thread = threading.Thread(
                target=self.backup_step_clock_loop
            )
            self.backup_step_clock_thread.start()

            if self.publish_slow_timer:
                self.publish_slow_timer.shutdown()
                self.publish_slow_timer.join()
            if self.publish_fast_timer:
                self.publish_fast_timer.shutdown()
                self.publish_fast_timer.join()
            print("    Shutdown fast and slow timers complete")

            self.kill_backup_clock_event.set()
            self.backup_step_clock_thread.join()

            self.tick_count = 0

            if os.path.exists(xml_file):
                prob_path = xml_file
            else:
                prob_path = os.path.join(self.pkg_path, "xmls", xml_file)
            self.ws_xml_path = os.path.abspath(prob_path)

            # * set up xml references
            root = ET.parse(self.ws_xml_path).getroot()
            compiler = root.find("compiler")
            meshdir = compiler.get("meshdir", compiler.get("assetdir", "./"))
            if not os.path.isabs(meshdir):
                meshdir = os.path.dirname(self.ws_xml_path) + "/" + meshdir
            self.assets = {None: None}
            for asset in root.find("asset"):
                if "file" in asset.keys():
                    name = asset.get("name")
                    path = asset.get("file")
                    if not os.path.isabs(path):
                        path = os.path.abspath(meshdir + path)
                    self.assets[name] = path
            self.geom2body = {}
            self.geom_type = {}
            for geom in root.findall(".//geom"):
                mat = np.eye(4)
                if "quat" in geom.keys():
                    quat = [float(x) for x in geom.get("quat").split()]
                    mat[:3, :3] = tf.quaternion_matrix(quat)[:3, :3]
                if "pos" in geom.keys():
                    pos = [float(x) for x in geom.get("pos").split()]
                    mat[:3, 3] = pos
                if self.assets[geom.get("mesh")] is not None:
                    self.geom2body[geom.get("mesh")] = mat
                    self.geom_type[geom.get("mesh")] = "mesh"
                else:
                    self.geom2body[geom.get("name")] = mat
                    self.geom_type[geom.get("name")] = geom.get("type")

            # * set up mujoco
            self.model = mujoco.MjModel.from_xml_path(prob_path)
            self.model.vis.global_.offheight = 1080
            self.model.vis.global_.offwidth = 1920
            self.model.opt.timestep = 0.002
            self.data = mujoco.MjData(self.model)
            self.gui = gui
            self.set_viewer()
            self.renderer = None
            self.save_image_dir = save_image_dir
            if self.save_image_dir is not None:
                os.makedirs(save_image_dir + "/rgb", exist_ok=True)
                os.makedirs(save_image_dir + "/depth", exist_ok=True)
                os.makedirs(save_image_dir + "/masks", exist_ok=True)

            self.experiment_dir = experiment_dir

            # Unregister publishers if they already exist
            if hasattr(self, "rgb_cam_pub"):
                pubs: List[rospy.Publisher] = [
                    pub
                    for pub_list in [
                        self.rgb_cam_pub,
                        self.depth_cam_pub,
                        self.seg_cam_pub,
                        self.cam_info_pub,
                        self.cam_tf_pub,
                    ]
                    for pub in pub_list
                ]
                for pub in pubs:
                    pub.unregister()

            self.rgb_cam_pub = [None for i in range(self.model.ncam)]
            self.depth_cam_pub = [None for i in range(self.model.ncam)]
            self.seg_cam_pub = [None for i in range(self.model.ncam)]
            self.cam_info_pub = [None for i in range(self.model.ncam)]
            self.cam_tf_pub = [None for i in range(self.model.ncam)]
            for i in range(self.model.ncam):
                self.rgb_cam_pub[i] = rospy.Publisher(
                    f"/camera{i}/color/image_raw", Image, queue_size=5
                )
                self.depth_cam_pub[i] = rospy.Publisher(
                    f"/camera{i}/aligned_depth_to_color/image_raw", Image, queue_size=5
                )
                self.seg_cam_pub[i] = rospy.Publisher(
                    f"/ground_truth/camera{i}/seg_image", Image, queue_size=5
                )
                self.cam_info_pub[i] = rospy.Publisher(
                    f"/camera{i}/color/camera_info", CameraInfo, queue_size=5
                )
                self.cam_tf_pub[i] = rospy.Publisher(
                    f"/tf_camera/camera{i}", TransformStamped, queue_size=3
                )

            self.cam_intrinsics = [None for i in range(self.model.ncam)]
            self.cam_extrinsics = [None for i in range(self.model.ncam)]
            self.joint_limit = self.get_joint_limit(self.joint_names)
            self.set_joint_angle(self.init_joints)

            # Unregister publishers if they already exist
            if hasattr(self, "gt_pub_selected"):
                for pub in [self.gt_pub_selected, self.gt_pub_selected_name]:
                    if pub:
                        pub.unregister()
            if self.gui and self.viewer is not None:
                self.gt_pub_selected = rospy.Publisher(
                    "/ground_truth/selected_object_id", Int32, queue_size=1
                )
                self.gt_pub_selected_name = rospy.Publisher(
                    "/ground_truth/selected_object_name", String, queue_size=1
                )

            self.set_ros_param()
            self.model_ready = True

            mujoco.mj_step(self.model, self.data)

            self.publish_slow_timer = rospy.Timer(
                float_to_ros_duration(PUBLISH_SLOW_DURATION), self.publish_slow
            )
            self.publish_fast_timer = rospy.Timer(
                float_to_ros_duration(PUBLISH_FAST_DURATION), self.publish_fast
            )

            print("    Restart fast and slow timers")
            print("    RESET FINISHED")

    def preempt_cb(self):
        rospy.loginfo("Preempted trajectory!!!")
        self.arm_trajectory = None
        result = FollowJointTrajectoryResult()
        result.error_code = actionlib.GoalStatus.PREEMPTED
        self.follow_trajectory_as.set_preempted(result)

    def follow_trajectory_cb(self):
        pass

    def get_objq_indices(self, obj_name):
        jnt = self.model.joint(self.model.body(obj_name).jntadr[0])
        qpos_inds = np.array(range(jnt.qposadr[0], jnt.qposadr[0] + len(jnt.qpos0)))
        return qpos_inds

    def get_qpos_indices(self, joints):
        qpos_inds = np.array([self.model.joint(j).qposadr[0] for j in joints])
        return qpos_inds

    def get_qvel_indices(self, joints):
        qvel_inds = np.array([self.model.joint(j).dofadr[0] for j in joints])
        return qvel_inds

    def get_ctrl_indices(self, joints, prefix="", replace=""):
        ctrl_name = lambda j: prefix + j.replace("_joint", replace)
        ctrl_inds = [self.model.actuator(ctrl_name(j)).id for j in joints]
        return np.array(ctrl_inds)

    def get_act_indices(self, joints, prefix="", replace=""):
        act_name = lambda j: prefix + j.replace("_joint", replace)
        act_inds = [self.model.actuator(act_name(j)).actadr[0] for j in joints]
        return np.array(act_inds)

    def get_jnt_indices(self, joints):
        jnt_inds = np.array([self.model.joint(j).id for j in joints])
        return jnt_inds

    def get_site_id(self, obj_name):
        site_id = self.model.site(f"{obj_name}_site").id
        return site_id

    def get_equality_id(self, obj_name):
        equality_id = self.model.equality(f"{obj_name}_weld").id
        return equality_id

