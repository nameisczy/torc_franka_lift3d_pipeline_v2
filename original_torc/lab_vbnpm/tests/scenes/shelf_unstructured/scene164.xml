      </default>
      <default class="coupler">
        <joint solreflimit="0.005" solimplimit="0.95 0.99" range="-1.57 0" armature="0.001"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="1"/>
      </default>
      <default class="collision">
